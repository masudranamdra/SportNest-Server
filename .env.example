# ============================================
# BACKEND SERVER CONFIGURATION
# ============================================

# Server Port (only used in local development)
# On Vercel, ignore this - it uses serverless functions
PORT=5000

# Node Environment
NODE_ENV=production

# ============================================
# MONGODB CONFIGURATION (CRITICAL)
# ============================================
# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/sportnest?retryWrites=true&w=majority&appName=Cluster0

# MongoDB Connection Pool Size (for serverless functions)
# Recommended: 10-20 for serverless
MONGODB_MAX_POOL_SIZE=10

# ============================================
# CORS & FRONTEND CONFIGURATION (CRITICAL)
# ============================================
# Frontend URL - must match your Vercel frontend deployment
# Development: http://localhost:3000
# Production: https://sportnest-mdra.vercel.app
CLIENT_URL=https://sportnest-mdra.vercel.app

# ============================================
# BETTER AUTH CONFIGURATION (CRITICAL)
# ============================================
# Better Auth Secret - generate a strong random string (32+ characters)
# Used for signing session cookies
BETTER_AUTH_SECRET=your_better_auth_secret_key_here_32_characters_minimum

# Better Auth Frontend URL - must match frontend deployment
# Development: http://localhost:3000
# Production: https://sportnest-mdra.vercel.app
BETTER_AUTH_URL=https://sportnest-mdra.vercel.app

# ============================================
# GOOGLE OAUTH CONFIGURATION (CRITICAL)
# ============================================
# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# RATE LIMITING CONFIGURATION (OPTIONAL)
# ============================================
# Max requests per 15 minutes per IP
# Default: 300 (recommended for production)
RATE_LIMIT_MAX=300
